    "\n",
    "# === Load CSV ===\n",
    "df = pd.read_csv(CSV_PATH)\n",
    "if SOURCE_COL not in df.columns:\n",
    "    SOURCE_COL = 'title'\n",
    "    print(f\"Column 'lab_group' not found. Falling back to 'title'.\")\n",
    "\n",
    "# === Normalization & Rule Matching ===\n",
    "def normalize_basic(s: str) -> str:\n",
    "    s = s.lower().strip()\n",
    "    s = re.sub(r\"[-_/]\", \" \", s)\n",
    "    s = re.sub(r\"\\s+\", \" \", s)\n",
    "    return s\n",
    "\n",
    "def titlecase_basic(s: str) -> str:\n",
    "    return \" \".join(w.capitalize() for w in s.split())\n",
    "\n",
    "def refine_label(text: str) -> str:\n",
    "    \"\"\"Return canonical label if rule matches, else 'unlabeled'.\"\"\"\n",
    "    txt = str(text).lower()\n",
    "    for pat, label in RULES:\n",
    "        if re.search(pat, txt):\n",
    "            return label\n",
    "    return \"unlabeled\"\n",
    "\n",
    "# Editable rules: (pattern, label)\n",
