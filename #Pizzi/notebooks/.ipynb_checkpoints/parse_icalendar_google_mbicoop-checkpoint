    "# refine 'titles' column to derive Lab names\n",
    "\n",
    "import re\n",
    "from collections import defaultdict, Counter\n",
    "\n",
    "titles = events_df['title'].dropna().unique().tolist()\n",
    "\n",
    "# ---- Helpers ----\n",
    "def normalize_whitespace(s: str) -> str:\n",
    "    s = s.strip()\n",
    "    s = re.sub(r\"[-_]+\", \" \", s)             # hyphens/underscores -> space\n",
    "    s = re.sub(r\"\\s+\", \" \", s)               # collapse spaces\n",
    "    return s\n",
    "\n",
    "def tokens(s: str):\n",
    "    return re.findall(r\"[a-z]+\", s.lower())\n",
    "\n",
    "def canonical_group_from_tokens(tokset):\n",
    "    # Padilla-Coreano cluster\n",
    "    if \"padilla\" in tokset and \"coreano\" in tokset:\n",
    "        return \"Padilla-Coreano Lab\"\n",
    "    # Burke cluster\n",
    "    if \"burke\" in tokset:\n",
    "        return \"Burke Lab\"\n",
    "    return None\n",
    "\n",
    "def titlecase_words(words):\n",
    "    return \" \".join(w.capitalize() for w in words if w)\n",
    "\n",
    "STOP = {\"lab\"}  # tokens to ignore\n",
    "canonical_map = {}\n",
    "person_to_lab_counts = defaultdict(Counter)\n",
    "\n",
    "# Pass 1: obvious labs and collect person→lab co-occurrence\n",
    "for raw in titles:\n",
    "    base = normalize_whitespace(raw)\n",
    "    tok = set(tokens(base))\n",
    "\n",
    "    lab_label = canonical_group_from_tokens(tok)\n",
    "\n",
    "    if lab_label:\n",
    "        canonical_map[raw] = lab_label\n",
    "        # Collect possible person tokens\n",
    "        person_toks = [t for t in tok if t not in (STOP | {\"burke\",\"padilla\",\"coreano\"})]\n",
    "        for pt in person_toks:\n",
    "            person_to_lab_counts[pt][lab_label] += 1\n",
    "    else:\n",
    "        canonical_map[raw] = None\n",
    "\n",
    "# Resolve person token → lab if seen with one\n",
    "person_to_lab = {pt: ctr.most_common(1)[0][0] for pt, ctr in person_to_lab_counts.items()}\n",
    "\n",
    "# Pass 2: assign remaining names\n",
    "for raw, current in list(canonical_map.items()):\n",
    "    if current is not None:\n",
    "        continue\n",
    "    base = normalize_whitespace(raw)\n",
    "    tok_list = tokens(base)\n",
    "\n",
    "    mapped_lab = None\n",
    "    for t in tok_list:\n",
    "        if t in person_to_lab:\n",
    "            mapped_lab = person_to_lab[t]\n",
    "            break\n",
    "\n",
    "    if mapped_lab:\n",
    "        canonical_map[raw] = mapped_lab\n",
    "    else:\n",
    "        # Orphan → titlecased unique\n",
    "        person_only = [t for t in tok_list if t not in STOP]\n",
    "        pretty = titlecase_words(person_only) or base\n",
    "        canonical_map[raw] = pretty\n",
    "\n",
    "# Build summary\n",
    "clusters = defaultdict(list)\n",
    "for raw, canon in canonical_map.items():\n",
    "    clusters[canon].append(raw)\n",
    "\n",
    "summary = pd.DataFrame([\n",
    "    {\"cluster\": canon, \"size\": len(members)} for canon, members in clusters.items()\n",
    "]).sort_values(\"size\", ascending=False)\n",
    "\n",
    "print(\"=== Cluster Summary ===\")\n",
