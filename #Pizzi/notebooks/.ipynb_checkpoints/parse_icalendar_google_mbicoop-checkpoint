    "# Clean up CSV etc for export and sharing\n",
    "\n",
    "# import pandas as pd\n",
    "\n",
    "# --- 0) Ensure time-derived columns exist (date, year_week, weekday, hour) ---\n",
    "# If your CSV already has them, this will silently skip.\n",
    "if 'start' in df.columns:\n",
    "    df['start'] = pd.to_datetime(df['start'], errors='coerce')\n",
    "    if 'date' not in df:\n",
    "        df['date'] = df['start'].dt.date\n",
    "    if 'year_week' not in df:\n",
    "        df['year_week'] = df['start'].dt.isocalendar().week.astype(int)\n",
    "    if 'weekday' not in df:\n",
    "        df['weekday'] = df['start'].dt.day_name()\n",
    "    if 'hour' not in df:\n",
    "        df['hour'] = df['start'].dt.hour\n",
    "\n",
    "# --- 1) Ensure lab_label_v3 exists (refined labels with \"unlabeled\" fallback) ---\n",
    "# Requires `refine_label()` from your RULES. If you don't have it defined, let me know and I'll paste it again.\n",
    "if 'lab_label_v3' not in df.columns:\n",
    "    source_for_refine = 'lab_group' if 'lab_group' in df.columns else 'title'\n",
    "    df['lab_label_v3'] = df[source_for_refine].apply(refine_label)\n",
    "\n",
    "# --- 2) Rename \"unlabeled\" -> \"Maintenance\" in lab_label_v3 ---\n",
    "df['lab_label_v3'] = (\n",
    "    df['lab_label_v3']\n",
    "      .fillna('unlabeled')\n",
    "      .mask(df['lab_label_v3'].str.lower() == 'unlabeled', 'Maintenance')\n",
    ")\n",
    "\n",
    "# --- 3) Build the clean DataFrame in your desired order ---\n",
    "desired_cols = [\n",
    "    'calendar',\n",
    "    'lab_label_v3',\n",
    "    'date',\n",
    "    'duration_hours',\n",
    "    'year_week',\n",
    "    'weekday',\n",
    "    'hour',\n",
    "    'title',\n",
    "]\n",
    "\n",
    "# Sanity-check columns exist; if any are missing, raise a helpful error\n",
    "missing = [c for c in desired_cols if c not in df.columns]\n",
    "if missing:\n",
    "    raise KeyError(f\"These required columns are missing: {missing}\")\n",
    "\n",
    "clean_df = (\n",
    "    df.loc[:, desired_cols]\n",
    "      .sort_values(['date', 'calendar', 'lab_label_v3', 'title'])\n",
    "      .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "# --- 4) Save to CSV ---\n",
    "out_path = \"calendar_events_clean.csv\"\n",
    "clean_df.to_csv(out_path, index=False)\n",
    "print(f\"Saved {len(clean_df)} rows to {out_path}\")\n",
    "\n",
    "# Optional: quick peek\n",
    "clean_df.head(10)\n"
