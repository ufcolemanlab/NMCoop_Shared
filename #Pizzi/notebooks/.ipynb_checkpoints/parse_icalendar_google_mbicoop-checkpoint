   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved 873 events to /Users/jcoleman/Downloads/mbi.optical.coop@gmail.com.ical/calendar_events_flat.csv\n"
     ]
